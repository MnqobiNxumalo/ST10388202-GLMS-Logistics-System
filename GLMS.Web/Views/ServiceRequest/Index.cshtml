@model IEnumerable<GLMS.Web.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<h1>Service Request Management</h1>

<p>
    <a asp-controller="Contracts" asp-action="Index" class="btn btn-primary">+ New Service Request</a>
</p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No service requests found. Click "New Service Request" to create one.
    </div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Contract #</th>
                <th>Client</th>
                <th>Description</th>
                <th>Amount (USD)</th>
                <th>Amount (ZAR)</th>
                <th>Exchange Rate</th>
                <th>Status</th>
                <th>Request Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model)
            {
                <tr>
                    <td>@request.Id</td>
                    <td>@request.Contract?.ContractNumber</td>
                    <td>@request.Contract?.Client?.Name</td>
                    <td>@request.Description</td>
                    <td>$@request.AmountUSD.ToString("N2")</td>
                    <td>R @request.AmountZAR.ToString("N2")</td>
                    <td>@request.ExchangeRateUsed.ToString("N4")</td>
                    <td>
                        @if (request.Status == RequestStatus.Pending)
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (request.Status == RequestStatus.Approved)
                        {
                            <span class="badge bg-info">Approved</span>
                        }
                        else if (request.Status == RequestStatus.InProgress)
                        {
                            <span class="badge bg-primary">In Progress</span>
                        }
                        else if (request.Status == RequestStatus.Completed)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                    </td>
                    <td>@request.RequestDate.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@request.Id" class="btn btn-sm btn-info">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}