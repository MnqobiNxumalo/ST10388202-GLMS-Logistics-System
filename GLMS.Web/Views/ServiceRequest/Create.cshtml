@model GLMS.Shared.ViewModels.ServiceRequestViewModel

@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create Service Request</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="ContractId" />

            <div class="form-group mb-3">
                <label class="form-label">Contract</label>
                <input type="text" class="form-control" value="@Model.ContractDisplayName" disabled />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter service description..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="AmountUSD" class="form-label">Amount (USD)</label>
                <input asp-for="AmountUSD" id="AmountUSD" class="form-control" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="AmountUSD" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label">Amount (ZAR)</label>
                <input id="AmountZAR" class="form-control" readonly disabled placeholder="Will auto-calculate" />
                <small class="text-muted">Exchange rate: <span id="ExchangeRate">--</span> USD/ZAR</small>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Create Request</button>
            <a asp-controller="Contracts" asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#AmountUSD').on('input', function() {
                var usdAmount = $(this).val();

                if (usdAmount && usdAmount > 0) {
                    $.ajax({
                        url: '/ServiceRequest/GetZarAmount',
                        type: 'GET',
                        data: { usdAmount: usdAmount },
                        success: function(response) {
                            $('#AmountZAR').val(response.zarAmount.toFixed(2));
                            $('#ExchangeRate').text(response.rate.toFixed(4));
                        },
                        error: function() {
                            $('#AmountZAR').val('Error fetching rate');
                            $('#ExchangeRate').text('Error');
                        }
                    });
                } else {
                    $('#AmountZAR').val('');
                    $('#ExchangeRate').text('--');
                }
            });
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}