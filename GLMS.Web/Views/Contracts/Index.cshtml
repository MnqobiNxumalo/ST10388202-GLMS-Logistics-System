@using GLMS.Shared.Models
@model IEnumerable<GLMS.Shared.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
}

<h1>Contract Management Hub</h1>

<!-- Search/Filter Form -->
<div class="card mb-4">
    <div class="card-header">
        <h5>Filter Contracts</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-3">
                    <label>Start Date From</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.CurrentStartDate" />
                </div>
                <div class="col-md-3">
                    <label>End Date To</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.CurrentEndDate" />
                </div>
                <div class="col-md-3">
                    <label>Status</label>
                    <select name="status" class="form-control" asp-items="ViewBag.StatusList">
                        <option value="">-- All --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label>&nbsp;</label>
                    <div>
                        <button type="submit" class="btn btn-primary">Search</button>
                        <a asp-action="Index" class="btn btn-secondary">Reset</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Contracts Table -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>Contract #</th>
            <th>Client</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>PDF</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var contract in Model)
        {
            <tr>
                <td>@contract.ContractNumber</td>
                <td>@contract.Client?.Name</td>
                <td>@contract.StartDate.ToShortDateString()</td>
                <td>@contract.EndDate.ToShortDateString()</td>
                <td>
                    <span class="badge @GetStatusBadgeClass(contract.Status)">
                        @contract.Status
                    </span>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.PdfFilePath))
                    {
                        <a asp-action="DownloadPdf" asp-route-id="@contract.Id" class="btn btn-sm btn-info">
                            Download PDF
                        </a>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-sm btn-primary">Details</a>
                    <a asp-controller="ServiceRequest" asp-action="Create" asp-route-contractId="@contract.Id"
                       class="btn btn-sm btn-success">Create Request</a>
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(contract.PdfFilePath))
                    {
                        <a asp-action="DownloadPdf" asp-route-id="@contract.Id" class="btn btn-sm btn-info">Download</a>
                    }
                    else
                    {
                        <span class="text-muted">No PDF</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@functions {
    string GetStatusBadgeClass(ContractStatus status)
    {
        return status switch
        {
            ContractStatus.Active => "bg-success",
            ContractStatus.Draft => "bg-secondary",
            ContractStatus.Expired => "bg-danger",
            ContractStatus.OnHold => "bg-warning",
            _ => "bg-secondary"
        };
    }
}