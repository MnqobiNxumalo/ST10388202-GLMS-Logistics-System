@model GLMS.Shared.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h1>Contract Details</h1>

<div class="card">
    <div class="card-header bg-primary text-white">
        <h3>@Model.ContractNumber</h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Contract Number:</dt>
                    <dd class="col-sm-8">@Model.ContractNumber</dd>

                    <dt class="col-sm-4">Client:</dt>
                    <dd class="col-sm-8">@Model.Client?.Name</dd>

                    <dt class="col-sm-4">Start Date:</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                    <dt class="col-sm-4">End Date:</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
            <div class="col-md-6">
                <dl class="row">
                    <dt class="col-sm-4">Status:</dt>
                    <dd class="col-sm-8">
                        @if (Model.Status == ContractStatus.Active)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else if (Model.Status == ContractStatus.Expired)
                        {
                            <span class="badge bg-danger">Expired</span>
                        }
                        else if (Model.Status == ContractStatus.OnHold)
                        {
                            <span class="badge bg-warning">On Hold</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Draft</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Service Level:</dt>
                    <dd class="col-sm-8">@Model.ServiceLevel</dd>

                    <dt class="col-sm-4">Created:</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.TermsAndConditions))
        {
            <div class="mt-3">
                <h5>Terms & Conditions</h5>
                <p>@Model.TermsAndConditions</p>
            </div>
        }
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        <a asp-controller="ServiceRequest" asp-action="Create" asp-route-contractId="@Model.Id" class="btn btn-primary">Create Service Request</a>
    </div>
</div>